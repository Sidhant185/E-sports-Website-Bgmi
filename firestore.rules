rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to tournament settings and brackets for all users
    match /tournament_settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /tournament_brackets/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow write access to registrations only during open registration
    match /bgmi_teams/{document} {
      allow read: if true;
      allow write: if true; // Will be controlled by application logic
    }
    
    match /tekken_players/{document} {
      allow read: if true;
      allow write: if true; // Will be controlled by application logic
    }
    
    // Allow read access to tournaments and games for all users
    match /tournaments/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /games/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow users to create registrations
    match /registrations/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // Admin-only access for managing tournaments
    match /admin/{document} {
      allow read, write: if request.auth != null;
    }
  }
}
